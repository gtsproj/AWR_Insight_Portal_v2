          "format": "time_series",
          "rawSql": "SELECT snap_time AS time,\n  ROUND(AVG(cpu_per_exec_s)::numeric,2) AS \"Oracle CPU (s/exec)\"\nFROM awr_sql_cpu_time\nWHERE dbname='${dbname}' AND '${dbname}' != ''\n  AND instance='${instance}' AND '${instance}' != ''\n  AND '${start_snap}' != '' AND '${end_snap}' != ''\n  AND begin_snap BETWEEN split_part('${start_snap}',' - ',1)::int\n                     AND split_part('${end_snap}',' - ',1)::int\nGROUP BY snap_time ORDER BY snap_time",
          "refId": "Oracle_CPU"
        },
