      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "format": "time_series",
          "rawSql": "SELECT snap_time AS time,\n  event AS metric, pct_db_time AS \"Oracle Wait % DB Time\"\nFROM awr_foreground_wait_events\nWHERE dbname='${dbname}' AND '${dbname}' != ''\n  AND instance='${instance}' AND '${instance}' != ''\n  AND '${start_snap}' != '' AND '${end_snap}' != ''\n  AND begin_snap BETWEEN split_part('${start_snap}',' - ',1)::int\n                     AND split_part('${end_snap}',' - ',1)::int\n  AND event IN ('db file sequential read','db file scattered read','direct path read')\nORDER BY snap_time",
          "refId": "Oracle_IO"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "format": "time_series",
          "rawSql": "SELECT snap_time AS time, iowait_pct AS \"OS iowait %\"\nFROM sar_cpu_stats\nWHERE hostname='${hostname}' AND '${hostname}' != ''\n  AND '${start_snap}' != '' AND '${end_snap}' != ''\n  AND snap_time BETWEEN\n    (SELECT snap_time FROM awr_load_profile\n     WHERE dbname='${dbname}' AND instance='${instance}'\n     AND begin_snap=split_part('${start_snap}',' - ',1)::int LIMIT 1)\n    AND\n    (SELECT snap_time FROM awr_load_profile\n     WHERE dbname='${dbname}' AND instance='${instance}'\n     AND begin_snap=split_part('${end_snap}',' - ',1)::int LIMIT 1)\n  AND cpu='all'\nORDER BY snap_time",
          "refId": "SAR_IO"
        }
      ],
      "title": "Oracle I/O Wait Events % DB Time  vs  OS iowait %",
      "type": "timeseries"
    },
