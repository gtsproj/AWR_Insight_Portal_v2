          },
          "format": "time_series",
          "rawSql": "SELECT snap_time AS time, swap_used_mb AS \"Swap Used MB\"\nFROM sar_swap_stats\nWHERE hostname='${hostname}' AND '${hostname}' != ''\n  AND '${start_snap}' != '' AND '${end_snap}' != ''\n  AND snap_time BETWEEN\n    (SELECT snap_time FROM awr_load_profile\n     WHERE dbname='${dbname}' AND instance='${instance}'\n     AND begin_snap=split_part('${start_snap}',' - ',1)::int LIMIT 1)\n    AND\n    (SELECT snap_time FROM awr_load_profile\n     WHERE dbname='${dbname}' AND instance='${instance}'\n     AND begin_snap=split_part('${end_snap}',' - ',1)::int LIMIT 1)\nORDER BY snap_time",
          "refId": "SAR_SWAP"
        }
      ],
