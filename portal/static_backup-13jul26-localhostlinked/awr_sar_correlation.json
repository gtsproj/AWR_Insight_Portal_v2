      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "format": "time_series",
          "rawSql": "SELECT snap_time AS time,\n  device || ' util%' AS metric, util_pct AS value\nFROM sar_disk_stats\nWHERE hostname='${hostname}' AND '${hostname}' != ''\n  AND '${start_snap}' != '' AND '${end_snap}' != ''\n  AND snap_time BETWEEN\n    (SELECT snap_time FROM awr_load_profile\n     WHERE dbname='${dbname}' AND instance='${instance}'\n     AND begin_snap=split_part('${start_snap}',' - ',1)::int LIMIT 1)\n    AND\n    (SELECT snap_time FROM awr_load_profile\n     WHERE dbname='${dbname}' AND instance='${instance}'\n     AND begin_snap=split_part('${end_snap}',' - ',1)::int LIMIT 1)\nORDER BY snap_time",
          "refId": "SAR_DISK"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "format": "time_series",
          "rawSql": "SELECT snap_time AS time,\n  ROUND(AVG(physical_reads)::numeric,0) AS \"Oracle Physical Reads\"\nFROM awr_seg_phy_reads\nWHERE dbname='${dbname}' AND '${dbname}' != ''\n  AND instance='${instance}' AND '${instance}' != ''\n  AND '${start_snap}' != '' AND '${end_snap}' != ''\n  AND begin_snap BETWEEN split_part('${start_snap}',' - ',1)::int\n                     AND split_part('${end_snap}',' - ',1)::int\nGROUP BY snap_time ORDER BY snap_time",
          "refId": "Oracle_PhysRead"
        }
      ],
      "title": "OS Disk Utilisation % per Device",
      "type": "timeseries"
    }
