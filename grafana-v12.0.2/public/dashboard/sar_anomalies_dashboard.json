      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT\n  CASE severity\n    WHEN 'critical' THEN '🔴 CRITICAL'\n    WHEN 'alert'    THEN '🟠 ALERT'\n    ELSE                 '🟡 WARNING'\n  END AS \"Severity\",\n  hostname AS \"Hostname\",\n  to_char(snap_time,'YYYY-MM-DD HH24:MI') AS \"Snap Time\",\n  metric_source AS \"Source\",\n  metric_name   AS \"Metric\",\n  object_name   AS \"Object\",\n  ROUND(metric_value::numeric,3)    AS \"Current Value\",\n  ROUND(baseline_mean::numeric,3)   AS \"Baseline Mean\",\n  ROUND(baseline_stddev::numeric,4) AS \"Baseline StdDev\",\n  ROUND(z_score::numeric,2)         AS \"Deviation Score\"\nFROM sar_anomalies\nWHERE hostname = '${hostname}'\n  AND '${hostname}' != ''\nORDER BY ABS(z_score) DESC\nLIMIT 50"
        }
