      {
        "name": "from_time",
        "label": "From",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "ferwfz6k211j4b"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "query": "SELECT DISTINCT snap_time::text AS __text, snap_time::text AS __value FROM sar_cpu_stats WHERE hostname='$hostname' ORDER BY snap_time LIMIT 200;"
      },
      {
        "name": "to_time",
        "label": "To",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "ferwfz6k211j4b"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "query": "SELECT DISTINCT snap_time::text AS __text, snap_time::text AS __value FROM sar_cpu_stats WHERE hostname='$hostname' ORDER BY snap_time DESC LIMIT 200;"
      },
      {
        "name": "dbname",
