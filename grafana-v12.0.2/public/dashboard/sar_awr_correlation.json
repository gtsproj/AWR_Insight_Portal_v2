    {
      "id": 11,
      "type": "timeseries",
      "title": "Oracle CPU Time % vs OS CPU user/system %",
      "datasource": {
        "type": "postgres",
        "uid": "ferwfz6k211j4b"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "refId": "Oracle_CPU",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "rawSql": "SELECT snap_time AT TIME ZONE 'Asia/Kolkata' AS time,\n  ROUND(AVG(pct_cpu),1) AS \"Oracle CPU %\"\nFROM awr_sql_cpu_time\nWHERE dbname='$dbname' AND instance='$hostname' AND begin_snap BETWEEN split_part('$start_snap',' - ',1)::int AND split_part('$end_snap',' - ',1)::int\nGROUP BY snap_time ORDER BY snap_time"
        },
        {
          "refId": "SAR_CPU",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "rawSql": "SELECT snap_time AS time, usr_pct AS \"OS user %\", system_pct AS \"OS system %\" FROM sar_cpu_stats WHERE hostname = '$hostname' AND snap_time BETWEEN '$from_time'::timestamp AND '$to_time'::timestamp AND cpu='all' ORDER BY snap_time"
        }
      ],
      "fieldConfig": {
        "defaults": {
