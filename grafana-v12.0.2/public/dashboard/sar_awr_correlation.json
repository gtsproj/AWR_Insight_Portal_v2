        },
        "query": "SELECT '' AS label UNION ALL SELECT DISTINCT begin_snap::int || ' - ' || to_char(snap_time,'YYYY-MM-DD HH24:MI:SS') FROM awr_load_profile WHERE dbname='$dbname' ORDER BY label NULLS FIRST;"
