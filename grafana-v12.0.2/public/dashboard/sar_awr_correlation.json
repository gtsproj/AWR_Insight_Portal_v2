    {
      "id": 200,
      "type": "row",
      "title": "I/O Correlation: Oracle Wait vs OS iowait",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Oracle I/O Waits % DB Time  vs  OS iowait %",
      "datasource": {
        "type": "postgres",
        "uid": "ferwfz6k211j4b"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "refId": "Oracle_IO",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "rawSql": "SELECT snap_time AT TIME ZONE 'Asia/Kolkata' AS time,\n  event_name, pct_db_time AS \"Oracle Wait % DB Time\"\nFROM awr_foreground_wait_events\nWHERE dbname='$dbname' AND instance='$hostname' AND begin_snap BETWEEN split_part('$start_snap',' - ',1)::int AND split_part('$end_snap',' - ',1)::int AND event_name IN ('db file sequential read','db file scattered read','direct path read')\nORDER BY snap_time"
        },
        {
          "refId": "SAR_IO",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "rawSql": "SELECT snap_time AS time, iowait_pct AS \"OS iowait %\" FROM sar_cpu_stats WHERE hostname = '$hostname' AND snap_time BETWEEN '$from_time'::timestamp AND '$to_time'::timestamp AND cpu='all' ORDER BY snap_time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "OS iowait %"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
