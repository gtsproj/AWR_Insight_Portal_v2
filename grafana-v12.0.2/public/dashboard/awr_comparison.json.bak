  "panels": [
    {
      "id": 99,
      "type": "text",
      "title": "Navigation",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "<a href='${portal_url}' target='_self'>&#x2B05; Portal Home</a> &nbsp;|&nbsp; <a href='/d/awr-anomalies' target='_self'>&#x1F6A8; Anomaly Detection</a> &nbsp;|&nbsp; <a href='/d/fdv31-awr-nav' target='_self'>&#x1F4CC; Navigation Hub</a> &nbsp;|&nbsp; <a href='${portal_url}/comparison' target='_self'>&#x1F504; Manage Tags</a>",
        "mode": "html"
      },
      "transparent": true
    },
    {
      "id": 200,
      "type": "table",
      "title": "Comparison Period Info",
      "datasource": {
        "type": "postgres",
        "uid": "ferwfz6k211j4b"
      },
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT\n  tag_type AS \"Type\",\n  t.dbname AS \"Database\",\n  t.instance AS \"Instance\",\n  tag_name AS \"Tag\",\n  snap_start AS \"Start Snap\",\n  snap_end AS \"End Snap\",\n  (SELECT to_char(snap_time,'YYYY-MM-DD HH24:MI') FROM awr_load_profile\n   WHERE dbname=t.dbname AND instance=t.instance AND begin_snap=t.snap_start LIMIT 1) AS \"Start Time\",\n  (SELECT to_char(snap_time,'YYYY-MM-DD HH24:MI') FROM awr_load_profile\n   WHERE dbname=t.dbname AND instance=t.instance AND begin_snap=t.snap_end LIMIT 1) AS \"End Time\",\n  COALESCE(notes,'') AS \"Notes\"\nFROM awr_comparison_tags t\nWHERE t.tag_name IN ('$baseline_tag','$current_tag')\nORDER BY CASE tag_type WHEN 'baseline' THEN 1 ELSE 2 END",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "width": null
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Type"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Database"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Instance"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Start Snap"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "End Snap"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Start Time"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "End Time"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          }
        ]
      },
      "options": {
        "footer": {
          "show": false
        },
        "frameIndex": 0
      }
    },
    {
      "id": 201,
      "type": "row",
      "title": "Wait Events — Before vs After",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "table",
      "title": "Wait Events — Before vs After (Delta)",
      "datasource": {
        "type": "postgres",
        "uid": "ferwfz6k211j4b"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "WITH baseline AS (\n  SELECT event AS event_name, AVG(pct_db_time) AS pct_before, AVG(avg_wait_ms) AS ms_before\n  FROM awr_foreground_wait_events w\n  JOIN awr_comparison_tags t ON t.dbname=w.dbname AND t.instance=w.instance\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name='$baseline_tag' AND t.tag_type='baseline'\n  GROUP BY event\n),\ncurrent_data AS (\n  SELECT event AS event_name, AVG(pct_db_time) AS pct_after, AVG(avg_wait_ms) AS ms_after\n  FROM awr_foreground_wait_events w\n  JOIN awr_comparison_tags t ON t.dbname=w.dbname AND t.instance=w.instance\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name='$current_tag' AND t.tag_type='current'\n  GROUP BY event\n)\nSELECT\n  COALESCE(b.event_name,c.event_name) AS \"Wait Event\",\n  ROUND(COALESCE(b.pct_before,0),1) AS \"Before (% DB Time)\",\n  ROUND(COALESCE(c.pct_after,0),1) AS \"After (% DB Time)\",\n  ROUND(COALESCE(b.ms_before,0),2) AS \"Before Avg Wait (ms)\",\n  ROUND(COALESCE(c.ms_after,0),2) AS \"After Avg Wait (ms)\",\n  ROUND((COALESCE(c.pct_after,0)-COALESCE(b.pct_before,0))/NULLIF(COALESCE(b.pct_before,0),0)*100,1) AS \"Change %\"\nFROM baseline b FULL OUTER JOIN current_data c USING (event_name)\nWHERE COALESCE(b.pct_before,0)>1 OR COALESCE(c.pct_after,0)>1\nORDER BY ABS(COALESCE(c.pct_after,0)-COALESCE(b.pct_before,0)) DESC LIMIT 15",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          }
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Change %",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Change %"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 20
                    },
                    {
                      "color": "red",
                      "value": 50
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 202,
      "type": "row",
      "title": "SQL Performance — Before vs After",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "table",
      "title": "Top SQL — Elapsed Time Comparison",
      "datasource": {
        "type": "postgres",
        "uid": "ferwfz6k211j4b"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "WITH baseline AS (\n  SELECT sql_id, AVG(elapsed_time_per_exec_s) AS elapsed_before, SUM(executions) AS exec_before\n  FROM awr_sql_elapsed_time w\n  JOIN awr_comparison_tags t ON t.dbname=w.dbname AND t.instance=w.instance\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name='$baseline_tag' AND t.tag_type='baseline'\n  GROUP BY sql_id\n),\ncurrent_data AS (\n  SELECT sql_id, AVG(elapsed_time_per_exec_s) AS elapsed_after, SUM(executions) AS exec_after\n  FROM awr_sql_elapsed_time w\n  JOIN awr_comparison_tags t ON t.dbname=w.dbname AND t.instance=w.instance\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name='$current_tag' AND t.tag_type='current'\n  GROUP BY sql_id\n)\nSELECT\n  COALESCE(b.sql_id,c.sql_id) AS \"SQL ID\",\n  ROUND(COALESCE(b.elapsed_before,0),2) AS \"Before Avg Elapsed (s)\",\n  ROUND(COALESCE(c.elapsed_after,0),2) AS \"After Avg Elapsed (s)\",\n  COALESCE(b.exec_before,0)::INT AS \"Before Executions\",\n  COALESCE(c.exec_after,0)::INT AS \"After Executions\",\n  ROUND((COALESCE(c.elapsed_after,0)-COALESCE(b.elapsed_before,0))/NULLIF(COALESCE(b.elapsed_before,0),0)*100,1) AS \"Change %\"\nFROM baseline b FULL OUTER JOIN current_data c USING (sql_id)\nWHERE COALESCE(b.elapsed_before,0)>5 OR COALESCE(c.elapsed_after,0)>5\nORDER BY ABS(COALESCE(c.elapsed_after,0)-COALESCE(b.elapsed_before,0)) DESC LIMIT 15",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          }
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Change %",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Change %"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 20
                    },
                    {
                      "color": "red",
                      "value": 50
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 203,
      "type": "row",
      "title": "Load Profile — Before vs After",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "collapsed": false
    },
    {
      "id": 12,
      "type": "table",
      "title": "Load Profile Metrics Comparison",
      "datasource": {
        "type": "postgres",
        "uid": "ferwfz6k211j4b"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "WITH baseline AS (\n  SELECT metric, AVG(per_sec) AS val_before\n  FROM awr_load_profile w\n  JOIN awr_comparison_tags t ON t.dbname=w.dbname AND t.instance=w.instance\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name='$baseline_tag' AND t.tag_type='baseline'\n  GROUP BY metric\n),\ncurrent_data AS (\n  SELECT metric, AVG(per_sec) AS val_after\n  FROM awr_load_profile w\n  JOIN awr_comparison_tags t ON t.dbname=w.dbname AND t.instance=w.instance\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name='$current_tag' AND t.tag_type='current'\n  GROUP BY metric\n)\nSELECT\n  COALESCE(b.metric,c.metric) AS \"Metric\",\n  ROUND(COALESCE(b.val_before,0),2) AS \"Before (per sec)\",\n  ROUND(COALESCE(c.val_after,0),2) AS \"After (per sec)\",\n  ROUND((COALESCE(c.val_after,0)-COALESCE(b.val_before,0))/NULLIF(COALESCE(b.val_before,0),0)*100,1) AS \"Change %\"\nFROM baseline b FULL OUTER JOIN current_data c USING (metric)\nORDER BY ABS(COALESCE(c.val_after,0)-COALESCE(b.val_before,0))/NULLIF(COALESCE(b.val_before,0),0) DESC NULLS LAST LIMIT 20",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          }
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Change %",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Change %"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 20
                    },
                    {
                      "color": "red",
                      "value": 50
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ]
}