    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU \u2014 %user / %system / %iowait / %idle",
      "datasource": {
        "type": "postgres",
        "uid": "ferwfz6k211j4b"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT snap_time AS time, cpu,\n  usr_pct AS \"%user\", system_pct AS \"%system\",\n  iowait_pct AS \"%iowait\", idle_pct AS \"%idle\"\nFROM sar_cpu_stats\nWHERE hostname = '$hostname' AND snap_time BETWEEN '$from_time'::timestamp AND '$to_time'::timestamp AND cpu='all'\nORDER BY snap_time",
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          },
          "unit": "percent"
