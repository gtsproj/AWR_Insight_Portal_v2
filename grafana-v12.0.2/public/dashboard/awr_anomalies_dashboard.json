        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT\n  CASE severity\n    WHEN 'critical' THEN '🔴 CRITICAL'\n    WHEN 'alert'    THEN '🟠 ALERT'\n    ELSE                 '🟡 WARNING'\n  END AS \"Severity\",\n  to_char(snap_time,'YYYY-MM-DD HH24:MI') AS \"Snap Time\",\n  begin_snap   AS \"Snap\",\n  metric_source AS \"Source\",\n  object_name  AS \"Object / Event\",\n  ROUND(metric_value::numeric,2)    AS \"Current Value\",\n  ROUND(baseline_mean::numeric,2)   AS \"Baseline Mean\",\n  ROUND(baseline_stddev::numeric,2) AS \"Baseline StdDev\",\n  ROUND(z_score::numeric,2)         AS \"Deviation Score\"\nFROM awr_anomalies\nWHERE dbname='${dbname}' AND '${dbname}' != '' AND '${instance}' != ''\n  AND instance = '${instance}')\nORDER BY ABS(z_score) DESC\nLIMIT 50"
        }
