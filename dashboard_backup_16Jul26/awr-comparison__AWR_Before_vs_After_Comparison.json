      "pluginVersion": "12.0.2",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH baseline AS (\n  SELECT event, AVG(pct_db_time) AS pct_before, AVG(avg_wait_ms) AS ms_before\n  FROM awr_foreground_wait_events w\n  JOIN awr_comparison_tags t ON t.dbname = w.dbname\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name = '$baseline_tag' AND t.tag_type = 'baseline'\n  WHERE w.dbname = '$dbname'\n  GROUP BY event\n),\ncurrent_data AS (\n  SELECT event, AVG(pct_db_time) AS pct_after, AVG(avg_wait_ms) AS ms_after\n  FROM awr_foreground_wait_events w\n  JOIN awr_comparison_tags t ON t.dbname = w.dbname\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name = '$current_tag' AND t.tag_type = 'current'\n  WHERE w.dbname = '$dbname'\n  GROUP BY event\n)\nSELECT\n  COALESCE(b.event, c.event) AS \"Wait Event\",\n  ROUND(COALESCE(b.pct_before,0),1) AS \"Before (% DB Time)\",\n  ROUND(COALESCE(c.pct_after,0),1) AS \"After (% DB Time)\",\n  ROUND(COALESCE(b.ms_before,0),2) AS \"Before Avg Wait (ms)\",\n  ROUND(COALESCE(c.ms_after,0),2) AS \"After Avg Wait (ms)\",\n  ROUND((COALESCE(c.pct_after,0) - COALESCE(b.pct_before,0)) /\n        NULLIF(COALESCE(b.pct_before,0),0) * 100, 1) AS \"Change %\"\nFROM baseline b FULL OUTER JOIN current_data c USING (event)\nWHERE COALESCE(b.pct_before,0) > 1 OR COALESCE(c.pct_after,0) > 1\nORDER BY ABS(COALESCE(c.pct_after,0) - COALESCE(b.pct_before,0)) DESC\nLIMIT 15",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Wait Events — Before vs After (Delta)",
      "type": "table"
    },
