      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "format": "table",
          "rawSql": "WITH baseline AS (\n  SELECT metric, AVG(per_sec) AS val_before\n  FROM awr_load_profile w\n  JOIN awr_comparison_tags t ON t.dbname = w.dbname\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name = '$baseline_tag' AND t.tag_type = 'baseline'\n  WHERE w.dbname = '$dbname'\n  GROUP BY metric\n),\ncurrent_data AS (\n  SELECT metric, AVG(per_sec) AS val_after\n  FROM awr_load_profile w\n  JOIN awr_comparison_tags t ON t.dbname = w.dbname\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name = '$current_tag' AND t.tag_type = 'current'\n  WHERE w.dbname = '$dbname'\n  GROUP BY metric\n)\nSELECT\n  COALESCE(b.metric, c.metric) AS \"Metric\",\n  ROUND(COALESCE(b.val_before,0),2) AS \"Before (per sec)\",\n  ROUND(COALESCE(c.val_after,0),2) AS \"After (per sec)\",\n  ROUND((COALESCE(c.val_after,0) - COALESCE(b.val_before,0)) /\n        NULLIF(COALESCE(b.val_before,0),0) * 100, 1) AS \"Change %\"\nFROM baseline b FULL OUTER JOIN current_data c USING (metric)\nORDER BY ABS(COALESCE(c.val_after,0) - COALESCE(b.val_before,0)) / NULLIF(COALESCE(b.val_before,0),0) DESC NULLS LAST\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Load Profile Metrics Comparison",
