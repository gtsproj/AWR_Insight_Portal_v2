      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH baseline AS (\n  SELECT sql_id, AVG(elapsed_time_s) AS elapsed_before, SUM(executions) AS exec_before\n  FROM awr_sql_elapsed_time w\n  JOIN awr_comparison_tags t ON t.dbname = w.dbname\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name = '$baseline_tag' AND t.tag_type = 'baseline'\n  WHERE w.dbname = '$dbname'\n  GROUP BY sql_id\n),\ncurrent_data AS (\n  SELECT sql_id, AVG(elapsed_time_s) AS elapsed_after, SUM(executions) AS exec_after\n  FROM awr_sql_elapsed_time w\n  JOIN awr_comparison_tags t ON t.dbname = w.dbname\n    AND w.begin_snap BETWEEN t.snap_start AND t.snap_end\n    AND t.tag_name = '$current_tag' AND t.tag_type = 'current'\n  WHERE w.dbname = '$dbname'\n  GROUP BY sql_id\n)\nSELECT\n  COALESCE(b.sql_id, c.sql_id) AS \"SQL ID\",\n  ROUND(COALESCE(b.elapsed_before,0),2) AS \"Before Avg Elapsed (s)\",\n  ROUND(COALESCE(c.elapsed_after,0),2) AS \"After Avg Elapsed (s)\",\n  COALESCE(b.exec_before,0)::INT AS \"Before Executions\",\n  COALESCE(c.exec_after,0)::INT AS \"After Executions\",\n  ROUND((COALESCE(c.elapsed_after,0) - COALESCE(b.elapsed_before,0)) /\n        NULLIF(COALESCE(b.elapsed_before,0),0) * 100, 1) AS \"Change %\"\nFROM baseline b FULL OUTER JOIN current_data c USING (sql_id)\nWHERE COALESCE(b.elapsed_before,0) > 5 OR COALESCE(c.elapsed_after,0) > 5\nORDER BY ABS(COALESCE(c.elapsed_after,0) - COALESCE(b.elapsed_before,0)) DESC\nLIMIT 15",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Top SQL — Elapsed Time Comparison",
      "type": "table"
