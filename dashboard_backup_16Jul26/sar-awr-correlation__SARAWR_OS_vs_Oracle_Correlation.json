          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT snap_time  AS time,\n  event, pct_db_time AS \"Oracle Wait % DB Time\"\nFROM awr_foreground_wait_events\nWHERE dbname='$dbname' \nAND instance='$instance' \nAND begin_snap BETWEEN split_part('$start_snap',' - ',1)::int AND split_part('$end_snap',' - ',1)::int \nAND event IN ('db file sequential read','db file scattered read','direct path read')\nORDER BY snap_time",
          "refId": "Oracle_IO",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "ferwfz6k211j4b"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT snap_time AS time, iowait_pct AS \"OS iowait %\"\r\nFROM sar_cpu_stats\r\nWHERE hostname='${hostname}' AND '${hostname}' != ''  \r\nAND '${start_snap}' != '' AND '${end_snap}' != ''  \r\nAND snap_time BETWEEN    \r\n(SELECT snap_time FROM awr_load_profile     \r\nWHERE dbname='${dbname}' \r\nAND instance='${instance}'     \r\nAND begin_snap=split_part('${start_snap}',' - ',1)::int LIMIT 1)    \r\nAND (SELECT snap_time \r\nFROM awr_load_profile     \r\nWHERE dbname='${dbname}' \r\nAND instance='${instance}'     \r\nAND begin_snap=split_part('${end_snap}',' - ',1)::int LIMIT 1)  \r\nAND cpu='all'\r\nORDER BY snap_time",
          "refId": "SAR_IO",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Oracle I/O Waits % DB Time  vs  OS iowait %",
      "type": "timeseries"
