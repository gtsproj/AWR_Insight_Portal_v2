          "format": "table",
          "rawSql": "SELECT\n  sql_id AS \"SQL ID\",\n  ROUND(SUM(elapsed_time_s),1) AS \"Total Elapsed (s)\",\n  ROUND(AVG(elapsed_time_s),2) AS \"Avg Elapsed (s)\",\n  SUM(executions)::INT AS \"Executions\",\n  ROUND(SUM(cpu_time_s),1) AS \"Total CPU (s)\",\n  CASE WHEN SUM(elapsed_time_s)>3600 THEN '🔴 CRITICAL'\n       WHEN SUM(elapsed_time_s)>300  THEN '🟠 HIGH'\n       WHEN SUM(elapsed_time_s)>60   THEN '🟡 MEDIUM'\n       ELSE '🟢 LOW' END AS \"Severity\"\nFROM awr_sql_elapsed\nWHERE dbname = '$dbname' AND instance = '$instance'\n  AND begin_snap BETWEEN split_part('$start_snap',' - ',1)::int AND split_part('$end_snap',' - ',1)::int\n  AND '$dbname' != '' AND '$instance' != ''\nGROUP BY sql_id\nORDER BY \"Total Elapsed (s)\" DESC NULLS LAST\nLIMIT 10",
          "refId": "A"
