          },
          "format": "table",
          "rawSql": "SELECT\n  event_name AS \"Wait Event\",\n  ROUND(AVG(pct_db_time),1) AS \"% DB Time\",\n  ROUND(AVG(avg_wait_ms),2) AS \"Avg Wait (ms)\",\n  SUM(total_waits) AS \"Total Waits\",\n  CASE WHEN AVG(pct_db_time)>20 THEN '🔴 CRITICAL'\n       WHEN AVG(pct_db_time)>10 THEN '🟠 HIGH'\n       WHEN AVG(pct_db_time)>5  THEN '🟡 MEDIUM'\n       ELSE '🟢 LOW' END AS \"Severity\"\nFROM awr_foreground_wait_events\nWHERE dbname = '$dbname' AND instance = '$instance'\n  AND begin_snap BETWEEN split_part('$start_snap',' - ',1)::int AND split_part('$end_snap',' - ',1)::int\n  AND '$dbname' != '' AND '$instance' != ''\nGROUP BY event_name\nORDER BY \"% DB Time\" DESC NULLS LAST\nLIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top 10 Wait Events — % DB Time",
      "type": "table"
    },
