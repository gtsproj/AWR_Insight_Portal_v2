          "rawSql": "SELECT\n  CASE severity\n    WHEN 'critical' THEN '🔴 CRITICAL'\n    WHEN 'high'     THEN '🟠 HIGH'\n    WHEN 'medium'   THEN '🟡 MEDIUM'\n    ELSE                 '🟢 LOW' END AS \"Severity\",\n  rule_id AS \"Rule ID\",\n  category AS \"Category\",\n  title AS \"Issue\",\n  event_or_object AS \"Event / Object\",\n  LEFT(root_cause, 150) AS \"Root Cause (summary)\"\nFROM awr_recommendations\nWHERE dbname = '$dbname'\n  AND begin_snap = split_part('$start_snap',' - ',1)::int\nORDER BY\n  CASE severity WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 ELSE 4 END,\n  category",
