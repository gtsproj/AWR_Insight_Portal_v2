        "name": "end_snap",
        "query": "SELECT begin_snap::text || ' - ' || to_char(snap_time,'YYYY-MM-DD HH24:MI:SS') AS label, begin_snap::text AS value FROM awr_sql_summary_mv WHERE dbname = '$dbname' AND instance = '$instance' ORDER BY begin_snap DESC",
