        "label": "SQL ID",
        "multi": false,
        "name": "sql_id",
        "query": "SELECT value, label \nFROM (  SELECT sql_id AS value, sql_id AS label,MAX(severity_score) AS severity_score  \nFROM awr_sql_summary_mv  \nWHERE dbname = '$dbname'    AND instance = '$instance'    \nAND begin_snap BETWEEN split_part('$start_snap',' - ',1)::int \nAND split_part('$end_snap',' - ',1)::int  \nGROUP BY sql_id  \nORDER BY MAX(severity_score) DESC   LIMIT 10) t \nORDER BY value",
